{
  "name": "interlis-web-ide",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc -b && node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "e2e": "playwright test",
    "e2e:public-clone": "RUN_PUBLIC_CLONE=1 playwright test e2e/public-clone.spec.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@ilic/diagram": "1.0.0-rc.1",
    "@ilic/docx": "1.0.0-rc.1",
    "@ilic/language-service": "1.0.0-rc.1",
    "@ilic/monaco-adapter": "1.0.0-rc.1",
    "@codingame/monaco-vscode-api": "35.0.1",
    "@codingame/monaco-vscode-configuration-service-override": "35.0.1",
    "@codingame/monaco-vscode-files-service-override": "35.0.1",
    "@codingame/monaco-vscode-keybindings-service-override": "35.0.1",
    "@codingame/monaco-vscode-quickaccess-service-override": "35.0.1",
    "@codingame/monaco-vscode-search-service-override": "35.0.1",
    "buffer": "6.0.3",
    "fflate": "^0.8.2",
    "isomorphic-git": "1.38.7",
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@35.0.1",
    "workbox-window": "7.4.1"
  }
}
